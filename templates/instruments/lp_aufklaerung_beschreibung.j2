{% for item in items %}
    {
      "id": "{{ item.id }}",
      "name": "{{ item.name }}",
      "rating": <0, 1 oder 2>,
      "justification": "<ein Satz>",
      "evidence": ["<[MM:SS] 'Zitat'>"]
    }{% if not loop.last %},{% endif %}
{% endfor %}
  ],
  "overall_note": "<2–3 Sätze Gesamtbewertung der Verfahrensbeschreibung>"
}
